@page "/myleads"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using QuoteTrack.Application.Interfaces
@using QuoteTrack.Domain.Entities
@using QuoteTrack.Domain.Enums
@inject IQuoteService QuoteService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager

<PageTitle>@(isAdminOrHead ? "Department Active Leads" : "My Active Leads")</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">
            <i class="bi bi-person-lines-fill text-primary me-2"></i>
            @(isAdminOrHead ? "Department Active Leads" : "My Active Leads")
        </h2>
        <div class="text-muted small">Sorted by newest by default. Click any column title to sort.</div>
    </div>
    <div>
        <span class="badge bg-primary rounded-pill fs-6 px-3 py-2 shadow-sm">@FilteredLeads().Count() Active</span>
    </div>
</div>

@if (isAdminOrHead)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-5">
                    <label class="form-label small fw-bold text-muted">Representative</label>
                    <select class="form-select" @bind="selectedOwnerId">
                        <option value="">All Representatives</option>
                        <option value="@UnassignedOwnerValue">Unassigned Only</option>
                        @foreach (var user in systemUsers.OrderBy(x => x.FullName))
                        {
                            <option value="@user.Id">@user.FullName</option>
                        }
                    </select>
                </div>

                <div class="col-md-5">
                    <label class="form-label small fw-bold text-muted">Search</label>
                    <input class="form-control" @bind="searchText" placeholder="Client / ref / subject / sender" />
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">
                        Clear
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(uiMessage))
{
    <div class="alert @(uiOk ? "alert-success" : "alert-danger") alert-dismissible fade show shadow-sm">
        @uiMessage
        <button type="button" class="btn-close" @onclick="() => uiMessage = string.Empty"></button>
    </div>
}

@if (isLoading)
{
    <div class="text-center mt-5"><div class="spinner-border text-primary"></div></div>
}
else if (!FilteredLeads().Any())
{
    <div class="card shadow-sm border-0 text-center py-5">
        <div class="card-body">
            <i class="bi bi-cup-hot text-muted" style="font-size: 3rem;"></i>
            <h4 class="mt-3 fw-bold text-dark">No Active Leads</h4>
            <p class="text-muted">Nothing matches the current filter.</p>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3" style="min-width: 240px;">
                                <a href="javascript:void(0)" class="text-white text-decoration-none" @onclick="() => SetSort(LeadSortColumn.ClientRef)">
                                    Client / Ref @SortIcon(LeadSortColumn.ClientRef)
                                </a>
                            </th>

                            @if (isAdminOrHead)
                            {
                                <th style="min-width: 180px;">
                                    <a href="javascript:void(0)" class="text-white text-decoration-none" @onclick="() => SetSort(LeadSortColumn.Owner)">
                                        Representative @SortIcon(LeadSortColumn.Owner)
                                    </a>
                                </th>
                            }

                            <th style="min-width: 120px;">
                                <a href="javascript:void(0)" class="text-white text-decoration-none" @onclick="() => SetSort(LeadSortColumn.Value)">
                                    Value @SortIcon(LeadSortColumn.Value)
                                </a>
                            </th>
                            <th style="min-width: 120px;">
                                <a href="javascript:void(0)" class="text-white text-decoration-none" @onclick="() => SetSort(LeadSortColumn.Status)">
                                    Status @SortIcon(LeadSortColumn.Status)
                                </a>
                            </th>
                            <th style="min-width: 160px;">
                                <a href="javascript:void(0)" class="text-white text-decoration-none" @onclick="() => SetSort(LeadSortColumn.NextDue)">
                                    Next Action Due @SortIcon(LeadSortColumn.NextDue)
                                </a>
                            </th>
                            <th style="min-width: 180px;">
                                <a href="javascript:void(0)" class="text-white text-decoration-none" @onclick="() => SetSort(LeadSortColumn.Received)">
                                    Received @SortIcon(LeadSortColumn.Received)
                                </a>
                            </th>
                            <th style="min-width: 280px;">
                                <a href="javascript:void(0)" class="text-white text-decoration-none" @onclick="() => SetSort(LeadSortColumn.LastNote)">
                                    Last Note @SortIcon(LeadSortColumn.LastNote)
                                </a>
                            </th>
                            <th style="min-width: 360px;">Quick Note + Due</th>
                            <th class="text-end pe-3" style="min-width: 120px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lead in SortedLeads())
                        {
                            var isOverdue = lead.NextFollowUpDate.HasValue && lead.NextFollowUpDate.Value < DateTime.UtcNow;
                            var lastNote = GetLastNote(lead);

                            <tr>
                                <td class="ps-3">
                                    <div class="fw-bold text-primary">
                                        @(lead.Client != null ? lead.Client.CompanyName : (string.IsNullOrWhiteSpace(lead.ClientName) ? "Unknown Client" : lead.ClientName))
                                    </div>
                                    <div class="small text-muted font-monospace">@((string.IsNullOrWhiteSpace(lead.QuoteReference)) ? "—" : lead.QuoteReference)</div>
                                    <div class="small text-muted text-truncate" style="max-width: 220px;" title="@lead.Subject">@lead.Subject</div>
                                </td>

                                @if (isAdminOrHead)
                                {
                                    <td>
                                        <span class="fw-bold">@(GetOwnerName(lead))</span>
                                    </td>
                                }

                                <td>
                                    <span class="fw-bold text-success">
                                        @(lead.QuoteValue.HasValue && lead.QuoteValue.Value > 0 ? $"{lead.Currency} {lead.QuoteValue.Value:N2}" : "TBD")
                                    </span>
                                </td>

                                <td>
                                    <span class="badge border border-secondary text-dark bg-light">@lead.Status.ToString()</span>
                                </td>

                                <td>
                                    @if (lead.NextFollowUpDate.HasValue)
                                    {
                                        <span class="badge @(isOverdue ? "bg-danger" : "bg-info text-dark")">
                                            @if (isOverdue)
                                            {
                                                <i class="bi bi-exclamation-circle-fill me-1"></i>
                                            }
                                            @lead.NextFollowUpDate.Value.ToLocalTime().ToString("MMM dd, yyyy")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small fst-italic">Not set</span>
                                    }
                                </td>

                                <td>
                                    <span class="small text-muted">@lead.EmailReceivedDateTime.ToLocalTime().ToString("dd MMM yyyy")</span>
                                </td>

                                <td>
                                    @if (lastNote != null)
                                    {
                                        <div class="small text-muted">@lastNote.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                        <div class="small text-truncate" style="max-width: 260px;" title="@lastNote.Notes">@lastNote.Notes</div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small fst-italic">No notes yet</span>
                                    }
                                </td>

                                <td>
                                    <div class="d-flex flex-column gap-2">
                                        <textarea class="form-control form-control-sm"
                                                  rows="2"
                                                  placeholder="Type a quick note..."
                                                  @bind="noteDraft[lead.Id]"></textarea>

                                        <div class="d-flex gap-2 align-items-center">
                                            <input type="date"
                                                   class="form-control form-control-sm"
                                                   style="max-width: 170px;"
                                                   @bind="dueDraft[lead.Id]"
                                                   @bind:format="yyyy-MM-dd" />
                                            <button class="btn btn-sm btn-warning fw-bold shadow-sm"
                                                    @onclick="() => SaveQuickNote(lead)">
                                                Save Note
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary fw-bold"
                                                    title="Clear draft"
                                                    @onclick="() => ClearDraft(lead.Id)">
                                                Clear
                                            </button>
                                        </div>
                                    </div>
                                </td>

                                <td class="text-end pe-3">
                                    <button class="btn btn-sm btn-outline-primary fw-bold shadow-sm"
                                            @onclick="() => NavigateToDetails(lead.Id)">
                                        Open <i class="bi bi-arrow-right-short"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private const string UnassignedOwnerValue = "__unassigned__";

    private bool isLoading = true;
    private bool isAdminOrHead = false;

    private List<Quote> myActiveLeads = new();
    private List<ApplicationUser> systemUsers = new();

    private string? currentUserId;

    private Dictionary<Guid, string> noteDraft = new();
    private Dictionary<Guid, DateTime> dueDraft = new();

    private string uiMessage = "";
    private bool uiOk = true;

    private LeadSortColumn sortColumn = LeadSortColumn.Received;
    private bool sortAsc = false;

    private string selectedOwnerId = "";
    private string searchText = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity != null && authState.User.Identity.IsAuthenticated)
        {
            currentUserId = UserManager.GetUserId(authState.User);

            var isAdmin = authState.User.IsInRole("Admin");
            var isHead = authState.User.IsInRole("DeptHead") ||
                         authState.User.IsInRole("DepartmentHead") ||
                         authState.User.IsInRole("Head") ||
                         authState.User.IsInRole("Manager");

            isAdminOrHead = isAdmin || isHead;
        }

        await LoadData();
        isLoading = false;
    }

    private async Task LoadData()
    {
        if (string.IsNullOrEmpty(currentUserId) && !isAdminOrHead) return;

        systemUsers = await QuoteService.GetSystemUsersAsync();

        var allQuotes = await QuoteService.GetAllQuotesAsync(isAdminOrHead ? null : currentUserId, isAdminOrHead);

        myActiveLeads = allQuotes.Where(q =>
    q.RecordType == QuoteRecordType.Lead &&
    !q.IsDeleteRequested &&
    q.Status != QuoteStatus.LeadClosed &&
    q.Status != QuoteStatus.LeadRepCompleted &&
    q.Status != QuoteStatus.Won &&
    q.Status != QuoteStatus.Lost &&
    q.Status != QuoteStatus.Cancelled &&
    q.Status != QuoteStatus.Merged
).ToList();

        foreach (var q in myActiveLeads)
        {
            if (!noteDraft.ContainsKey(q.Id)) noteDraft[q.Id] = "";
            if (!dueDraft.ContainsKey(q.Id))
            {
                dueDraft[q.Id] = q.NextFollowUpDate?.ToLocalTime().Date ?? DateTime.Today.AddDays(1);
            }
        }
    }

    private IEnumerable<Quote> FilteredLeads()
    {
        IEnumerable<Quote> q = myActiveLeads;

        if (isAdminOrHead)
        {
            if (!string.IsNullOrWhiteSpace(selectedOwnerId))
            {
                if (selectedOwnerId == UnassignedOwnerValue)
                    q = q.Where(x => string.IsNullOrWhiteSpace(x.OwnerId));
                else
                    q = q.Where(x => x.OwnerId == selectedOwnerId);
            }

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                var s = searchText.Trim();

                q = q.Where(x =>
                    (x.Client?.CompanyName ?? x.ClientName ?? x.SenderEmail ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (x.QuoteReference ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (x.Subject ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (x.SenderEmail ?? "").Contains(s, StringComparison.OrdinalIgnoreCase));
            }
        }

        return q;
    }

    private IEnumerable<Quote> SortedLeads()
    {
        var q = FilteredLeads();

        Func<Quote, object?> key = sortColumn switch
        {
            LeadSortColumn.ClientRef => (x) => (x.Client?.CompanyName ?? x.ClientName ?? x.SenderEmail ?? ""),
            LeadSortColumn.Owner => (x) => GetOwnerName(x),
            LeadSortColumn.Value => (x) => x.QuoteValue ?? 0m,
            LeadSortColumn.Status => (x) => x.Status.ToString(),
            LeadSortColumn.NextDue => (x) => x.NextFollowUpDate ?? DateTime.MaxValue,
            LeadSortColumn.LastNote => (x) => GetLastNote(x)?.CreatedAt ?? DateTime.MinValue,
            _ => (x) => x.EmailReceivedDateTime
        };

        return sortAsc ? q.OrderBy(key) : q.OrderByDescending(key);
    }

    private void SetSort(LeadSortColumn col)
    {
        if (sortColumn == col)
            sortAsc = !sortAsc;
        else
        {
            sortColumn = col;
            sortAsc = col is LeadSortColumn.Received or LeadSortColumn.NextDue or LeadSortColumn.LastNote ? false : true;
        }
    }

    private string SortIcon(LeadSortColumn col)
    {
        if (sortColumn != col) return "";
        return sortAsc ? " ▲" : " ▼";
    }

    private FollowUp? GetLastNote(Quote q)
    {
        if (q.FollowUps == null || q.FollowUps.Count == 0) return null;
        return q.FollowUps.OrderByDescending(x => x.CreatedAt).FirstOrDefault();
    }

    private string GetOwnerName(Quote lead)
    {
        if (lead.Owner != null && !string.IsNullOrWhiteSpace(lead.Owner.FullName))
            return lead.Owner.FullName;

        if (!string.IsNullOrWhiteSpace(lead.OwnerId))
        {
            var u = systemUsers.FirstOrDefault(x => x.Id == lead.OwnerId);
            if (u != null) return u.FullName;
        }

        return "Unassigned";
    }

    private async Task SaveQuickNote(Quote lead)
    {
        uiMessage = "";
        uiOk = true;

        if (string.IsNullOrWhiteSpace(currentUserId))
        {
            uiOk = false;
            uiMessage = "User session missing. Please re-login.";
            return;
        }

        var note = noteDraft.TryGetValue(lead.Id, out var n) ? n : "";
        if (string.IsNullOrWhiteSpace(note))
        {
            uiOk = false;
            uiMessage = "Please type a note before saving.";
            return;
        }

        var due = dueDraft.TryGetValue(lead.Id, out var d) ? d : DateTime.Today.AddDays(1);
        var dueUtc = new DateTime(due.Year, due.Month, due.Day, 12, 0, 0, DateTimeKind.Local).ToUniversalTime();

        try
        {
            lead.NextFollowUpDate = dueUtc;
            await QuoteService.UpdateQuoteAsync(lead, currentUserId);

            await QuoteService.AddFollowUpAsync(new FollowUp
            {
                QuoteId = lead.Id,
                Notes = note.Trim(),
                DueDate = dueUtc,
                IsCompleted = false,
                CreatedByUserId = currentUserId
            });

            noteDraft[lead.Id] = "";
            uiOk = true;
            uiMessage = $"Note saved for {(string.IsNullOrWhiteSpace(lead.QuoteReference) ? lead.Id.ToString() : lead.QuoteReference)}";
            await LoadData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            uiOk = false;
            uiMessage = "Failed to save note: " + ex.Message;
        }
    }

    private void ClearDraft(Guid id)
    {
        if (noteDraft.ContainsKey(id)) noteDraft[id] = "";
        if (dueDraft.ContainsKey(id)) dueDraft[id] = DateTime.Today.AddDays(1);
    }

    private void ClearFilters()
    {
        selectedOwnerId = "";
        searchText = "";
    }

    private void NavigateToDetails(Guid id)
    {
        NavManager.NavigateTo($"/lead/{id}");
    }

    private enum LeadSortColumn
    {
        ClientRef,
        Owner,
        Value,
        Status,
        NextDue,
        Received,
        LastNote
    }
}
