@page "/lead/{Id:guid}"
@rendermode InteractiveServer
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Identity
@using QuoteTrack.Application.Interfaces
@using QuoteTrack.Domain.Entities
@using QuoteTrack.Domain.Enums

@inject IQuoteService QuoteService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

<PageTitle>Lead Details</PageTitle>

<style>
    .qt-iframe {
        width: 100%;
        height: 560px;
        border: 1px solid #eee;
        border-radius: 10px;
        background: #fff;
    }

    .qt-tline-wrap {
        border: 1px solid #eee;
        border-radius: 14px;
        background: #fff;
        padding: 12px 12px 10px 12px;
    }

    .qt-tline {
        display: flex;
        gap: 10px;
        flex-wrap: nowrap;
        overflow-x: auto;
        padding-bottom: 8px;
    }

    .qt-step {
        min-width: 220px;
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 10px 12px;
        background: #fafafa;
        flex: 0 0 auto;
    }

        .qt-step .title {
            font-weight: 800;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

    .qt-pill {
        display: inline-block;
        padding: 2px 10px;
        border-radius: 999px;
        font-size: 12px;
        background: #fca311;
        color: #111;
        font-weight: 800;
    }

    .qt-step .meta {
        font-size: 12px;
        color: #666;
        margin-top: 4px;
    }

    .qt-step .desc {
        font-size: 12px;
        color: #777;
        margin-top: 6px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .qt-events {
        margin-top: 10px;
        border-top: 1px solid #eee;
        padding-top: 10px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
    }

        .qt-events .left {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            align-items: center;
        }

    .qt-chip {
        border: 1px solid #eee;
        border-radius: 999px;
        padding: 6px 10px;
        background: #fff;
        font-size: 12px;
        color: #444;
        display: inline-flex;
        gap: 8px;
        align-items: center;
    }

        .qt-chip b {
            color: #111;
        }

        .qt-chip .when {
            color: #666;
        }

    .qt-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.55);
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .qt-modal {
        width: min(1100px, 95vw);
        height: min(740px, 92vh);
        background: #fff;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,0.35);
        display: flex;
        flex-direction: column;
    }

    .qt-modal-header {
        padding: 10px 14px;
        background: #111;
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
    }

    .qt-modal-body {
        flex: 1;
        background: #fff;
    }

        .qt-modal-body iframe {
            width: 100%;
            height: 100%;
            border: 0;
        }
</style>

@if (isLoading)
{
    <div class="text-center mt-5"><div class="spinner-border text-primary"></div></div>
}
else if (lead == null)
{
    <div class="alert alert-danger">Lead not found.</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <button class="btn btn-outline-secondary btn-sm mb-2" @onclick="BackToMyLeads">
                <i class="bi bi-arrow-left me-1"></i> Back to My Leads
            </button>
            <h2 class="mb-0"><i class="bi bi-inbox-fill text-primary me-2"></i>Lead Record</h2>
            <div class="text-muted small">
                <span class="me-2"><b>Subject:</b> @lead.Subject</span>
                <span class="me-2"><b>Received:</b> @lead.EmailReceivedDateTime.ToLocalTime()</span>
                <span class="me-2"><b>From:</b> @lead.SenderEmail</span>
            </div>
        </div>

        <div class="text-end">
            <span class="badge @GetLeadStatusBadgeClass(lead.Status) fs-5 px-3 py-2 shadow-sm">Status: @lead.Status</span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(uiMessage))
    {
        <div class="alert @(uiOk ? "alert-success" : "alert-danger") alert-dismissible fade show shadow-sm">
            @uiMessage
            <button type="button" class="btn-close" @onclick="() => uiMessage = string.Empty"></button>
        </div>
    }

    <!-- HORIZONTAL TIMELINE -->
    <div class="qt-tline-wrap shadow-sm mb-3">
        <div class="qt-tline">
            <div class="qt-step">
                <div class="title"><span class="qt-pill">1</span> Email Received</div>
                <div class="meta">@lead.EmailReceivedDateTime.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</div>
                <div class="desc" title="@lead.Subject">@lead.Subject</div>
            </div>

            <div class="qt-step">
                <div class="title"><span class="qt-pill">2</span> Record Created</div>
                <div class="meta">@lead.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</div>
                <div class="desc">NexTraQ created this lead entry</div>
            </div>

            <div class="qt-step">
                <div class="title"><span class="qt-pill">3</span> Current Status</div>
                <div class="meta">@lead.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</div>
                <div class="desc">Status: @lead.Status</div>
            </div>

            <div class="qt-step">
                <div class="title"><span class="qt-pill">4</span> Next Action</div>
                <div class="meta">@((lead.NextFollowUpDate.HasValue) ? lead.NextFollowUpDate.Value.ToLocalTime().ToString("dd MMM yyyy") : "Not set")</div>
                <div class="desc">Owner: @(lead.Owner?.FullName ?? "Unassigned")</div>
            </div>

            <div class="qt-step">
                <div class="title"><span class="qt-pill">5</span> Last Note</div>
                <div class="meta">@((lastNoteAt.HasValue) ? lastNoteAt.Value.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt") : "-")</div>
                <div class="desc">@((lastNoteText ?? "No notes yet"))</div>
            </div>
        </div>

        <div class="qt-events">
            <div class="left">
                @foreach (var ev in recentEvents)
                {
                    <span class="qt-chip" title="@ev.Details">
                        <b>@ev.Title</b>
                        <span class="when">@ev.WhenUtc.ToLocalTime().ToString("dd MMM, hh:mm tt")</span>
                    </span>
                }
            </div>

            <div class="small text-muted">
                <b>Total Notes:</b> @((lead.FollowUps?.Count ?? 0)) • <b>Attachments:</b> @((lead.Attachments?.Count ?? 0))
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- LEFT: Lead info + EML -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-white border-bottom fw-bold py-3">Lead Summary</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted">Client (Extracted)</label>
                            <input class="form-control" @bind="lead.ClientName" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted">Sender Email</label>
                            <input class="form-control" value="@lead.SenderEmail" disabled />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted">Lead Status</label>
                            <select class="form-select border-warning" @bind="lead.Status">
                                @foreach (var s in LeadStatusOptions)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted">Owner</label>
                            <select class="form-select border-warning" @bind="lead.OwnerId">
                                <option value="">-- Unassigned --</option>
                                @foreach (var u in users.OrderBy(x => x.FullName))
                                {
                                    <option value="@u.Id">@u.FullName</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted">Lead Source</label>
                            <input class="form-control" @bind="lead.LeadSource" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted">Next Action Due</label>
                            <input type="date" class="form-control" @bind="nextDueLocal" @bind:format="yyyy-MM-dd" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-warning fw-bold shadow-sm" @onclick="SaveLeadHeader">
                            <i class="bi bi-save2 me-1"></i> Save Lead
                        </button>
                        <button class="btn btn-outline-secondary fw-bold" @onclick="Reload">
                            Refresh
                        </button>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-white border-bottom fw-bold py-3">Discovery / Requirements Notes</div>
                <div class="card-body">
                    <textarea class="form-control" rows="10" @bind="discoveryNotes"></textarea>
                    <div class="d-flex gap-2 mt-3">
                        <button class="btn btn-primary fw-bold" @onclick="SaveDiscoveryNotes">
                            Save Notes
                        </button>
                        <span class="text-muted small align-self-center">
                            Last updated:
                            @(lead.DiscoveryNotesUpdatedAt.HasValue? lead.DiscoveryNotesUpdatedAt.Value.ToLocalTime().ToString() : "-")
                        </span>
                    </div>
                </div>
            </div>

            <!-- FIXED EML PREVIEW (LEFT) -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold py-3 d-flex justify-content-between align-items-center">
                    <span>Original Email (.eml)</span>
                    @if (fixedEmlAttachmentId != null)
                    {
                        <a class="btn btn-sm btn-outline-light fw-bold"
                               target="_blank"
                               href="@("/api/attachments/download/" + fixedEmlAttachmentId)">
                            Download EML
                        </a>
                    }
                </div>
                <div class="card-body">
                    @if (fixedEmlAttachmentId == null)
                    {
                        <div class="text-muted small">No .eml attachment found for this lead.</div>
                    }
                    else
                    {
                        <iframe class="qt-iframe" src="@("/api/attachments/emlview/" + fixedEmlAttachmentId)"></iframe>
                    }
                </div>
            </div>
        </div>

        <!-- RIGHT: Attachments + Notes -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-white border-bottom fw-bold py-3 d-flex justify-content-between align-items-center">
                    <span>Attachments</span>
                    <InputFile OnChange="UploadAttachment" />
                </div>
                <div class="card-body">
                    @if (lead.Attachments == null || lead.Attachments.Count == 0)
                    {
                        <div class="text-muted small">No attachments.</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var a in lead.Attachments.OrderByDescending(x => x.CreatedAt))
                            {
                                var isPdf = IsPdf(a);
                                var isEml = IsEml(a);

                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="text-truncate" style="max-width:70%;" title="@a.FileName">
                                            <div class="fw-bold">@a.FileName</div>
                                            <div class="text-muted small">@a.ContentType • @FormatSize(a.FileSize)</div>
                                        </div>

                                        <div class="d-flex gap-2">
                                            <a class="btn btn-sm btn-outline-primary fw-bold"
                                                   target="_blank"
                                                   href="@("/api/attachments/download/" + a.Id)">
                                                Download
                                            </a>

                                            @if (isPdf)
                                            {
                                                <button class="btn btn-sm btn-outline-secondary fw-bold"
                                                        @onclick="() => OpenPdfModal(a.Id, a.FileName)">
                                                    Preview PDF
                                                </button>
                                            }

                                            @if (isEml)
                                            {
                                                <button class="btn btn-sm btn-outline-secondary fw-bold"
                                                        @onclick="() => SetFixedEml(a.Id)">
                                                    Set EML
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- NOTES RIGHT -->
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-dark text-white fw-bold py-3">Notes / Follow-ups</div>
                <div class="card-body">
                    <textarea class="form-control mb-2" rows="2" placeholder="Add a note..." @bind="newNote"></textarea>

                    <div class="d-flex gap-2">
                        <input type="date" class="form-control" style="max-width:170px;" @bind="noteDueLocal" @bind:format="yyyy-MM-dd" />
                        <button class="btn btn-warning fw-bold w-100" @onclick="AddTimelineNote">
                            Add Note
                        </button>
                    </div>

                    <hr />

                    @if (lead.FollowUps == null || lead.FollowUps.Count == 0)
                    {
                        <div class="text-muted small">No notes yet.</div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var f in lead.FollowUps.OrderByDescending(x => x.CreatedAt))
                            {
                                <div class="list-group-item px-0 py-2">
                                    <div class="d-flex justify-content-between">
                                        <div class="small text-muted">@f.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</div>
                                        <div class="small text-muted">Due: @f.DueDate.ToLocalTime().ToString("dd MMM")</div>
                                    </div>
                                    <div class="small fw-bold">@f.Notes</div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- REP COMPLETION -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom fw-bold py-3">Rep Completion (Attach Outgoing Quote)</div>
                <div class="card-body">
                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted">Outgoing Quote Reference</label>
                            <input class="form-control" @bind="repQuoteRef" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted">Rep Notes</label>
                            <input class="form-control" @bind="repNotes" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button class="btn btn-success fw-bold shadow-sm w-100" @onclick="SubmitLeadAsRepComplete">
                            Submit for Admin Closure
                        </button>
                    </div>

                    <div class="text-muted small mt-2">
                        Rep Submitted At: @(lead.RepCompletedAt.HasValue? lead.RepCompletedAt.Value.ToLocalTime().ToString() : "-")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- PDF MODAL -->
    @if (showPdfModal && pdfModalAttachmentId != null)
    {
        <div class="qt-modal-overlay" @onclick="ClosePdfModal">
            <div class="qt-modal" @onclick:stopPropagation="true">
                <div class="qt-modal-header">
                    <div class="fw-bold text-truncate" style="max-width: 75%;">
                        PDF Preview: @pdfModalTitle
                    </div>
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-light fw-bold"
                               target="_blank"
                               href="@("/api/attachments/download/" + pdfModalAttachmentId)">
                            Download
                        </a>
                        <button class="btn btn-sm btn-warning fw-bold" @onclick="ClosePdfModalBtn">Close</button>
                    </div>
                </div>
                <div class="qt-modal-body">
                    <iframe src="@("/api/attachments/inline/" + pdfModalAttachmentId)"></iframe>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool isLoading = true;
    private Quote? lead;

    private List<ApplicationUser> users = new();
    private string? currentUserId;
    private bool isAdmin;

    private DateTime nextDueLocal = DateTime.Today.AddDays(1);

    private string discoveryNotes = "";

    // notes
    private string newNote = "";
    private DateTime noteDueLocal = DateTime.Today.AddDays(1);

    // rep completion
    private string repQuoteRef = "";
    private string repNotes = "";

    private string uiMessage = "";
    private bool uiOk = true;

    // fixed eml
    private Guid? fixedEmlAttachmentId;

    // pdf modal
    private bool showPdfModal = false;
    private Guid? pdfModalAttachmentId;
    private string pdfModalTitle = "";

    // timeline summary
    private DateTime? lastNoteAt;
    private string? lastNoteText;
    private List<TimelineEvent> recentEvents = new();

    private static readonly List<QuoteStatus> LeadStatusOptions = new()
    {
        QuoteStatus.LeadNew,
        QuoteStatus.Assigned,
        QuoteStatus.InProgress,
        QuoteStatus.ContactMade,
        QuoteStatus.WaitingClientResponse,
        QuoteStatus.QuotationInPreparation,
        QuoteStatus.OnHold,
        QuoteStatus.NoResponse,
        QuoteStatus.LeadClosed
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;

        currentUserId = UserManager.GetUserId(principal);
        isAdmin = principal.IsInRole("Admin");

        users = await QuoteService.GetSystemUsersAsync();

        await Load();
        isLoading = false;
    }

    private void BackToMyLeads() => Nav.NavigateTo("/myleads");

    private async Task Reload()
    {
        await Load();
        uiOk = true;
        uiMessage = "Refreshed.";
    }

    private async Task Load()
    {
        lead = await QuoteService.GetQuoteByIdAsync(Id);
        if (lead == null) return;

        discoveryNotes = lead.DiscoveryNotes ?? "";
        repQuoteRef = lead.RepAttachedQuoteReference ?? "";
        repNotes = lead.RepCompletionNotes ?? "";

        if (lead.NextFollowUpDate.HasValue)
            nextDueLocal = lead.NextFollowUpDate.Value.ToLocalTime().Date;

        noteDueLocal = DateTime.Today.AddDays(1);

        fixedEmlAttachmentId = lead.Attachments?
            .Where(IsEml)
            .OrderByDescending(a => a.CreatedAt)
            .Select(a => (Guid?)a.Id)
            .FirstOrDefault();

        BuildTimelineSummary();
    }

    private void BuildTimelineSummary()
    {
        recentEvents = new List<TimelineEvent>();

        if (lead == null) return;

        if (lead.FollowUps != null && lead.FollowUps.Count > 0)
        {
            var last = lead.FollowUps.OrderByDescending(x => x.CreatedAt).First();
            lastNoteAt = last.CreatedAt;
            lastNoteText = last.Notes;
        }
        else
        {
            lastNoteAt = null;
            lastNoteText = null;
        }

        recentEvents.Add(new TimelineEvent
        {
            WhenUtc = lead.EmailReceivedDateTime,
            Title = "Received",
            Details = lead.Subject
        });

        recentEvents.Add(new TimelineEvent
        {
            WhenUtc = lead.CreatedAt,
            Title = "Created",
            Details = "Record created"
        });

        recentEvents.Add(new TimelineEvent
        {
            WhenUtc = lead.UpdatedAt,
            Title = "Updated",
            Details = $"Status: {lead.Status}"
        });

        if (lead.FollowUps != null)
        {
            foreach (var f in lead.FollowUps.OrderByDescending(x => x.CreatedAt).Take(3))
            {
                recentEvents.Add(new TimelineEvent
                {
                    WhenUtc = f.CreatedAt,
                    Title = "Note",
                    Details = f.Notes
                });
            }
        }

        recentEvents = recentEvents
            .OrderByDescending(x => x.WhenUtc)
            .Take(6)
            .ToList();
    }

    private async Task SaveLeadHeader()
    {
        if (lead == null) return;

        try
        {
            var dueUtc = new DateTime(nextDueLocal.Year, nextDueLocal.Month, nextDueLocal.Day, 12, 0, 0, DateTimeKind.Local).ToUniversalTime();
            lead.NextFollowUpDate = dueUtc;

            await QuoteService.UpdateQuoteAsync(lead, currentUserId);

            uiOk = true;
            uiMessage = "Lead saved.";

            Nav.NavigateTo("/myleads");
        }
        catch (Exception ex)
        {
            uiOk = false;
            uiMessage = "Save failed: " + ex.Message;
        }
    }

    private async Task SaveDiscoveryNotes()
    {
        if (lead == null) return;

        try
        {
            lead.DiscoveryNotes = discoveryNotes;
            lead.DiscoveryNotesUpdatedAt = DateTime.UtcNow;
            lead.DiscoveryNotesUpdatedByUserId = currentUserId;

            await QuoteService.UpdateQuoteAsync(lead, currentUserId);

            uiOk = true;
            uiMessage = "Discovery notes saved.";
            await Load();
        }
        catch (Exception ex)
        {
            uiOk = false;
            uiMessage = "Save failed: " + ex.Message;
        }
    }

    private async Task AddTimelineNote()
    {
        if (lead == null || string.IsNullOrWhiteSpace(currentUserId)) return;

        if (string.IsNullOrWhiteSpace(newNote))
        {
            uiOk = false;
            uiMessage = "Please type a note.";
            return;
        }

        try
        {
            var dueUtc = new DateTime(noteDueLocal.Year, noteDueLocal.Month, noteDueLocal.Day, 12, 0, 0, DateTimeKind.Local).ToUniversalTime();
            lead.NextFollowUpDate = dueUtc;
            await QuoteService.UpdateQuoteAsync(lead, currentUserId);

            await QuoteService.AddFollowUpAsync(new FollowUp
            {
                QuoteId = lead.Id,
                Notes = newNote.Trim(),
                DueDate = dueUtc,
                IsCompleted = false,
                CreatedByUserId = currentUserId
            });

            newNote = "";
            uiOk = true;
            uiMessage = "Note added.";
            await Load();
        }
        catch (Exception ex)
        {
            uiOk = false;
            uiMessage = "Failed: " + ex.Message;
        }
    }

    private async Task SubmitLeadAsRepComplete()
    {
        if (lead == null || string.IsNullOrWhiteSpace(currentUserId)) return;

        if (string.IsNullOrWhiteSpace(repQuoteRef))
        {
            uiOk = false;
            uiMessage = "Outgoing quote reference is required.";
            return;
        }

        try
        {
            await QuoteService.SubmitLeadAsRepCompleteAsync(lead.Id, currentUserId, repQuoteRef.Trim(), repNotes?.Trim());
            uiOk = true;
            uiMessage = "Submitted for admin closure.";
            await Load();
        }
        catch (Exception ex)
        {
            uiOk = false;
            uiMessage = "Submit failed: " + ex.Message;
        }
    }

    private async Task UploadAttachment(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file == null) return;

            var client = HttpClientFactory.CreateClient();
            using var content = new MultipartFormDataContent();

            var stream = file.OpenReadStream(maxAllowedSize: 50_000_000);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);

            content.Add(fileContent, "file", file.Name);

            var res = await client.PostAsync("/api/attachments/upload/" + Id, content);
            if (!res.IsSuccessStatusCode)
            {
                uiOk = false;
                uiMessage = "Upload failed: " + res.StatusCode;
                return;
            }

            uiOk = true;
            uiMessage = "Attachment uploaded successfully.";
            await Load();
        }
        catch (Exception ex)
        {
            uiOk = false;
            uiMessage = "Upload error: " + ex.Message;
        }
    }

    private void OpenPdfModal(Guid id, string title)
    {
        pdfModalAttachmentId = id;
        pdfModalTitle = title ?? "";
        showPdfModal = true;
    }

    private void ClosePdfModal()
    {
        showPdfModal = false;
        pdfModalAttachmentId = null;
        pdfModalTitle = "";
    }

    private void ClosePdfModalBtn() => ClosePdfModal();

    private void SetFixedEml(Guid id) => fixedEmlAttachmentId = id;

    private bool IsPdf(Attachment a) =>
        (a.ContentType ?? "").Contains("pdf", StringComparison.OrdinalIgnoreCase)
        || (a.FileName ?? "").EndsWith(".pdf", StringComparison.OrdinalIgnoreCase);

    private bool IsEml(Attachment a) =>
        (a.FileName ?? "").EndsWith(".eml", StringComparison.OrdinalIgnoreCase)
        || (a.ContentType ?? "").Contains("message/rfc822", StringComparison.OrdinalIgnoreCase);

    private string FormatSize(long size)
    {
        if (size < 1024) return $"{size} B";
        if (size < 1024 * 1024) return $"{size / 1024.0:0.0} KB";
        return $"{size / (1024.0 * 1024.0):0.0} MB";
    }

    private string GetLeadStatusBadgeClass(QuoteStatus status)
    {
        return status switch
        {
            QuoteStatus.LeadClosed => "bg-dark text-white",
            QuoteStatus.NoResponse => "bg-danger text-white",
            QuoteStatus.OnHold => "bg-secondary text-white",
            QuoteStatus.QuotationInPreparation => "bg-primary text-white",
            QuoteStatus.WaitingClientResponse => "bg-info text-dark",
            QuoteStatus.ContactMade => "bg-success text-white",
            QuoteStatus.InProgress => "bg-primary text-white",
            QuoteStatus.Assigned => "bg-info text-dark",
            _ => "bg-warning text-dark"
        };
    }

    private class TimelineEvent
    {
        public DateTime WhenUtc { get; set; }
        public string Title { get; set; } = "";
        public string? Details { get; set; }
    }
}