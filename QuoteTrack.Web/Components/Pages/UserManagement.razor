@page "/admin/users"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using QuoteTrack.Domain.Entities
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager

<PageTitle>User Management</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people-fill text-primary me-2"></i>User Management</h2>
    <button class="btn btn-primary fw-bold shadow-sm" @onclick="ToggleAddUserForm">
        <i class="bi bi-person-plus-fill me-1"></i> Add New User
    </button>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger shadow-sm mb-4">@errorMessage</div>
}
@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success shadow-sm mb-4">@successMessage</div>
}

@if (showAddUserForm)
{
    <div class="card shadow-sm border-primary border-2 mb-4">
        <div class="card-header bg-primary text-white fw-bold">Create New User Account</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold small text-muted">Full Name</label>
                    <input type="text" class="form-control" @bind="newUserFullName" placeholder="e.g. Faraj" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold small text-muted">Email Address (Username)</label>
                    <input type="email" class="form-control" @bind="newUserEmail" placeholder="faraj@nexcel.me" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold small text-muted">Temporary Password</label>
                    <input type="text" class="form-control" @bind="newUserPassword" placeholder="e.g. Nexcel@2026!" />
                    <small class="text-muted" style="font-size: 0.7rem;">Must contain uppercase, number, & special char.</small>
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success fw-bold" @onclick="CreateUser">Create User</button>
                <button class="btn btn-outline-secondary bg-white" @onclick="ToggleAddUserForm">Cancel</button>
            </div>
        </div>
    </div>
}

@if (users == null)
{
    <div class="text-center mt-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">Full Name</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>System Roles</th>
                        <th class="pe-3 text-end">Danger Zone</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in users)
                    {
                        var isUserAdmin = adminUserIds.Contains(user.Id);
                        var isUserFinance = financeUserIds.Contains(user.Id);
                        var isUserHead = deptHeadIds.Contains(user.Id);

                        <tr>
                            <td class="ps-3 fw-bold">
                                <a href="/admin/users/@user.Id" class="text-decoration-none text-primary hover-primary">
                                    <i class="bi bi-person-badge me-1"></i> @user.FullName
                                </a>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                            <td>
                                @if (isUserAdmin)
                                {
                                    <span class="badge bg-primary me-1">Admin</span>
                                }
                                @if (isUserFinance)
                                {
                                    <span class="badge bg-info text-dark me-1">Finance</span>
                                }
                                @if (isUserHead)
                                {
                                    <span class="badge bg-dark">Dept Head</span>
                                }
                            </td>
                            <td class="pe-3 text-end">
                                <div class="btn-group shadow-sm">
                                    <button class="btn btn-sm @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                            @onclick="() => ToggleUserStatus(user.Id)" title="Toggle Account Status">
                                        @(user.IsActive ? "Deactivate" : "Activate")
                                    </button>

                                    <button class="btn btn-sm btn-outline-dark" @onclick='() => ToggleRole(user.Id, "DeptHead")'>
                                        @(isUserHead ? "Revoke Head" : "Make Head")
                                    </button>

                                    <button class="btn btn-sm btn-outline-info" @onclick='() => ToggleRole(user.Id, "Finance")'>
                                        @(isUserFinance ? "Revoke Finance" : "Make Finance")
                                    </button>

                                    <button class="btn btn-sm btn-outline-primary" @onclick='() => ToggleRole(user.Id, "Admin")'>
                                        @(isUserAdmin ? "Revoke Admin" : "Make Admin")
                                    </button>

                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteUser(user.Id)" title="Delete User">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<ApplicationUser>? users;
    private HashSet<string> adminUserIds = new(), financeUserIds = new(), deptHeadIds = new();

    // --- NEW ADD USER STATE VARIABLES ---
    private bool showAddUserForm = false;
    private string newUserFullName = string.Empty;
    private string newUserEmail = string.Empty;
    private string newUserPassword = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        users = await UserManager.Users.ToListAsync();
        adminUserIds.Clear(); financeUserIds.Clear(); deptHeadIds.Clear();

        foreach (var user in users)
        {
            if (await UserManager.IsInRoleAsync(user, "Admin")) adminUserIds.Add(user.Id);
            if (await UserManager.IsInRoleAsync(user, "Finance")) financeUserIds.Add(user.Id);
            if (await UserManager.IsInRoleAsync(user, "DeptHead")) deptHeadIds.Add(user.Id);
        }
    }

    // --- NEW ADD USER METHODS ---
    private void ToggleAddUserForm()
    {
        showAddUserForm = !showAddUserForm;
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }

    private async Task CreateUser()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(newUserEmail) || string.IsNullOrWhiteSpace(newUserPassword) || string.IsNullOrWhiteSpace(newUserFullName))
        {
            errorMessage = "Please fill in all fields.";
            return;
        }

        var user = new ApplicationUser
        {
            UserName = newUserEmail,
            Email = newUserEmail,
            FullName = newUserFullName,
            EmailConfirmed = true
        };

        var result = await UserManager.CreateAsync(user, newUserPassword);

        if (result.Succeeded)
        {
            successMessage = $"Successfully created user: {newUserFullName}!";
            showAddUserForm = false;
            newUserFullName = string.Empty;
            newUserEmail = string.Empty;
            newUserPassword = string.Empty;

            await LoadUsersAsync();
        }
        else
        {
            errorMessage = string.Join(" | ", result.Errors.Select(e => e.Description));
        }
    }

    private async Task ToggleUserStatus(string userId)
    {
        var user = await UserManager.FindByIdAsync(userId);
        if (user != null)
        {
            user.IsActive = !user.IsActive;
            await UserManager.UpdateAsync(user);
            await LoadUsersAsync();
        }
    }

    private async Task ToggleRole(string userId, string roleName)
    {
        if (!await RoleManager.RoleExistsAsync(roleName))
            await RoleManager.CreateAsync(new IdentityRole(roleName));

        var user = await UserManager.FindByIdAsync(userId);
        if (user != null)
        {
            if (await UserManager.IsInRoleAsync(user, roleName))
                await UserManager.RemoveFromRoleAsync(user, roleName);
            else
                await UserManager.AddToRoleAsync(user, roleName);

            await LoadUsersAsync();
        }
    }

    private async Task DeleteUser(string userId)
    {
        var user = await UserManager.FindByIdAsync(userId);
        if (user != null)
        {
            await UserManager.DeleteAsync(user);
            await LoadUsersAsync();
        }
    }
}