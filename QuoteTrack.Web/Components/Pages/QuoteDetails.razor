    private void CloseAddClientModal()
    {
        showAddClientModal = false;
        savingClient = false;
    }

    private async Task SaveNewClientFromQuote()
    {
        if (quote == null) return;
        if (savingClient) return;

        clientMessage = "";

        if (string.IsNullOrWhiteSpace(newClient.CompanyName))
        {
            clientMessageOk = false;
            clientMessage = "Company Name is required.";
            return;
        }

        savingClient = true;

        try
        {
            var allClients = await ClientService.GetAllClientsAsync();

            var existing = allClients.FirstOrDefault(c =>
                string.Equals((c.CompanyName ?? "").Trim(), newClient.CompanyName.Trim(), StringComparison.OrdinalIgnoreCase));

            if (existing != null)
            {
                if (existing.ApprovalStatus == ClientApprovalStatus.Approved)
                {
                    quote.ClientId = existing.Id;
                    await SaveQuote();

                    clientMessageOk = true;
                    clientMessage = "Existing approved client found and linked to this quote.";
                    showAddClientModal = false;
                    await Reload();
                    return;
                }
                else
                {
                    clientMessageOk = false;
                    clientMessage = "A client with the same name already exists in pending/review state.";
                    return;
                }
            }

            var approvalStatus = isAdminOrHead ? ClientApprovalStatus.Approved : ClientApprovalStatus.Pending;

            var entity = new Client
            {
                CompanyName = newClient.CompanyName.Trim(),
                Industry = TrimOrNull(newClient.Industry),
                PrimaryContactName = TrimOrNull(newClient.PrimaryContactName),
                Email = TrimOrNull(newClient.Email),
                Phone = TrimOrNull(newClient.Phone),
                CommercialRegistrationNumber = TrimOrNull(newClient.CommercialRegistrationNumber),
                TaxRegistrationNumber = TrimOrNull(newClient.TaxRegistrationNumber),
                BillingAddress = TrimOrNull(newClient.BillingAddress),
                ApprovalStatus = approvalStatus,
                SubmittedByUserId = currentUserId,
                ApprovedByUserId = approvalStatus == ClientApprovalStatus.Approved ? currentUserId : null,
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow
            };

            await ClientService.AddClientAsync(entity);

            if (approvalStatus == ClientApprovalStatus.Approved)
            {
                quote.ClientId = entity.Id;
                await SaveQuote();
                clientMessageOk = true;
                clientMessage = "Client added and linked to this quote successfully.";
            }
            else
            {
                clientMessageOk = true;
                clientMessage = "Client request submitted successfully for approval.";
            }

            showAddClientModal = false;
            await Reload();
        }
        catch (Exception ex)
        {
            clientMessageOk = false;
            clientMessage = "Error saving client: " + ex.Message;
        }
        finally
        {
            savingClient = false;
        }
    }

    private FollowUp? GetLatestFollowUp()
    {
        return quote?.FollowUps?
            .OrderByDescending(x => x.CreatedAt)
            .FirstOrDefault();
    }

    private string GetLastNoteTimeText()
    {
        var latest = GetLatestFollowUp();
        return latest == null
            ? "No notes yet"
            : latest.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt");
    }

    private string GetLastNotePreview()
    {
        var latest = GetLatestFollowUp();
        if (latest == null || string.IsNullOrWhiteSpace(latest.Notes))
            return "No notes available.";

        var text = latest.Notes.Trim();

        if (text.Length > 200)
            return text.Substring(0, 200) + "...";

        return text;
    }

    private string GetOwnerName()
    {
        if (quote == null) return "-";

        var owner = systemUsers.FirstOrDefault(x => x.Id == quote.OwnerId);
        if (owner != null && !string.IsNullOrWhiteSpace(owner.FullName))
            return owner.FullName;

        return "Unassigned";
    }

    private string? TrimOrNull(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return null;
        return s.Trim();
    }

    private string GetStatusBadgeClass(QuoteStatus s)
    {
        return s switch
        {
            QuoteStatus.Won => "bg-success",
            QuoteStatus.Lost => "bg-danger",
            QuoteStatus.Cancelled => "bg-secondary",
            QuoteStatus.Sent => "bg-primary",
            _ => "bg-warning text-dark"
        };
    }

