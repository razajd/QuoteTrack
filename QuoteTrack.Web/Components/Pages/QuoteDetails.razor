    private void OpenAddClientModal()
    {
        clientMessage = "";

        newClient = new QuoteClientInputModel
        {
            CompanyName = quote?.ClientName?.Trim() ?? "",
            Email = quote?.SenderEmail?.Trim() ?? ""
        };

        showAddClientModal = true;
