@page "/quotes"
@rendermode InteractiveServer
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using QuoteTrack.Application.Interfaces
@using QuoteTrack.Domain.Entities
@using QuoteTrack.Domain.Enums

@inject IQuoteService QuoteService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Quotes</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-1"><i class="bi bi-files text-primary me-2"></i>Quotes</h2>
        <div class="text-muted small">Newest first by default. Now paged for speed.</div>
    </div>
    <div>
        <span class="badge bg-primary rounded-pill fs-6 px-3 py-2 shadow-sm">@totalCount</span>
    </div>
</div>

@if (isAdmin)
{
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label small fw-bold text-muted">Filter by Salesperson (Owner)</label>
                    <select class="form-select" @bind="selectedOwnerId">
                        <option value="">All Salespersons</option>
                        @foreach (var u in systemUsers.OrderBy(x => x.FullName))
                        {
                            <option value="@u.Id">@u.FullName</option>
                        }
                    </select>
                </div>

                <div class="col-md-5">
                    <label class="form-label small fw-bold text-muted">Search (Client / Ref / Subject)</label>
                    <input class="form-control" @bind="searchText" placeholder="Type to filter..." />
                </div>

                <div class="col-md-1">
                    <button class="btn btn-primary w-100 fw-bold" @onclick="ApplyFiltersAsync">
                        Apply
                    </button>
                </div>

                <div class="col-md-1">
                    <button class="btn btn-outline-secondary w-100 fw-bold" @onclick="ClearFiltersAsync">
                        Clear
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (isLoading)
{
    <div class="text-center mt-5"><div class="spinner-border text-primary"></div></div>
}
else if (!pageQuotes.Any())
{
    <div class="alert alert-info">No quotes found for the current filter.</div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3" style="min-width:240px;">
                                <a href="javascript:void(0)" class="text-white text-decoration-none" @onclick="() => SetSortAsync(QuoteSortColumn.Client)">
                                    Client @SortIcon(QuoteSortColumn.Client)
                                </a>
                            </th>

                            <th style="min-width:160px;">
                                <a href="javascript:void(0)" class="text-white text-decoration-none" @onclick="() => SetSortAsync(QuoteSortColumn.Reference)">
                                    Reference @SortIcon(QuoteSortColumn.Reference)
                                </a>
                            </th>

                            <th style="min-width:140px;">
                                <a href="javascript:void(0)" class="text-white text-decoration-none" @onclick="() => SetSortAsync(QuoteSortColumn.Value)">
                                    Value @SortIcon(QuoteSortColumn.Value)
                                </a>
                            </th>

                            <th style="min-width:120px;">
                                <a href="javascript:void(0)" class="text-white text-decoration-none" @onclick="() => SetSortAsync(QuoteSortColumn.Status)">
                                    Status @SortIcon(QuoteSortColumn.Status)
                                </a>
                            </th>

                            @if (isAdmin)
                            {
                                <th style="min-width:180px;">
                                    <a href="javascript:void(0)" class="text-white text-decoration-none" @onclick="() => SetSortAsync(QuoteSortColumn.Owner)">
                                        Owner @SortIcon(QuoteSortColumn.Owner)
                                    </a>
                                </th>
                            }

                            <th style="min-width:160px;">
                                <a href="javascript:void(0)" class="text-white text-decoration-none" @onclick="() => SetSortAsync(QuoteSortColumn.NextDue)">
                                    Next Due @SortIcon(QuoteSortColumn.NextDue)
                                </a>
                            </th>

                            <th style="min-width:160px;">
                                <a href="javascript:void(0)" class="text-white text-decoration-none" @onclick="() => SetSortAsync(QuoteSortColumn.Created)">
                                    Created @SortIcon(QuoteSortColumn.Created)
                                </a>
                            </th>

                            <th class="text-end pe-3" style="min-width:110px;">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var q in pageQuotes)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-bold text-primary">
                                        @(q.Client?.CompanyName ?? q.ClientName ?? q.SenderEmail ?? "Unknown")
                                    </div>
                                    <div class="small text-muted text-truncate" style="max-width:260px;" title="@q.Subject">@q.Subject</div>
                                </td>

                                <td>
                                    <span class="font-monospace small">@((string.IsNullOrWhiteSpace(q.QuoteReference)) ? "—" : q.QuoteReference)</span>
                                </td>

                                <td>
                                    <span class="fw-bold text-success">
                                        @(q.QuoteValue.HasValue && q.QuoteValue.Value > 0 ? $"{q.Currency} {q.QuoteValue.Value:N2}" : "TBD")
                                    </span>
                                </td>

                                <td>
                                    <span class="badge border border-secondary text-dark bg-light">@q.Status.ToString()</span>
                                </td>

                                @if (isAdmin)
                                {
                                    <td>
                                        <span class="small text-muted">@((q.Owner != null) ? q.Owner.FullName : "—")</span>
                                    </td>
                                }

                                <td>
                                    @if (q.NextFollowUpDate.HasValue)
                                    {
                                        <span class="small text-muted">@q.NextFollowUpDate.Value.ToLocalTime().ToString("dd MMM yyyy")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small fst-italic">—</span>
                                    }
                                </td>

                                <td>
                                    <span class="small text-muted">@q.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</span>
                                </td>

                                <td class="text-end pe-3">
                                    <button class="btn btn-sm btn-outline-primary fw-bold shadow-sm" @onclick="() => OpenQuote(q.Id)">
                                        Open <i class="bi bi-arrow-right-short"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white border-top">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="small text-muted">
                    Showing page <b>@currentPage</b> of <b>@totalPages</b> • Total records: <b>@totalCount</b>
                </div>

                <div class="btn-group">
                    <button class="btn btn-outline-secondary btn-sm fw-bold" @onclick="() => GoToPageAsync(1)" disabled="@(currentPage <= 1)">
                        First
                    </button>
                    <button class="btn btn-outline-secondary btn-sm fw-bold" @onclick="() => GoToPageAsync(currentPage - 1)" disabled="@(currentPage <= 1)">
                        Prev
                    </button>
                    <button class="btn btn-outline-secondary btn-sm fw-bold" @onclick="() => GoToPageAsync(currentPage + 1)" disabled="@(currentPage >= totalPages)">
                        Next
                    </button>
                    <button class="btn btn-outline-secondary btn-sm fw-bold" @onclick="() => GoToPageAsync(totalPages)" disabled="@(currentPage >= totalPages)">
                        Last
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;

    private List<Quote> pageQuotes = new();
    private List<ApplicationUser> systemUsers = new();

    private string? currentUserId;
    private bool isAdmin;

    private string selectedOwnerId = "";
    private string searchText = "";

    private QuoteSortColumn sortColumn = QuoteSortColumn.Created;
    private bool sortAsc = false;

    private int currentPage = 1;
    private int pageSize = 25;
    private int totalCount = 0;
    private int totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;

        currentUserId = UserManager.GetUserId(principal);
        isAdmin = principal.IsInRole("Admin");

        systemUsers = await QuoteService.GetSystemUsersAsync();

        await LoadPageAsync(1);
    }

    private async Task LoadPageAsync(int pageNumber)
    {
        isLoading = true;
        StateHasChanged();

        if (pageNumber < 1)
            pageNumber = 1;

        totalCount = await QuoteService.GetQuotesPageCountAsync(
            currentUserId,
            isAdmin,
            selectedOwnerId,
            searchText);

        totalPages = totalCount <= 0 ? 1 : (int)Math.Ceiling(totalCount / (double)pageSize);

        if (pageNumber > totalPages)
            pageNumber = totalPages;

        currentPage = pageNumber;

        pageQuotes = await QuoteService.GetQuotesPageAsync(
            currentUserId,
            isAdmin,
            currentPage,
            pageSize,
            selectedOwnerId,
            searchText,
            sortColumn.ToString(),
            sortAsc);

        isLoading = false;
    }

    private async Task ApplyFiltersAsync()
    {
        await LoadPageAsync(1);
    }

    private async Task ClearFiltersAsync()
    {
        selectedOwnerId = "";
        searchText = "";
        await LoadPageAsync(1);
    }

    private async Task GoToPageAsync(int page)
    {
        await LoadPageAsync(page);
    }

    private async Task SetSortAsync(QuoteSortColumn col)
    {
        if (sortColumn == col)
        {
            sortAsc = !sortAsc;
        }
        else
        {
            sortColumn = col;
            sortAsc = col is QuoteSortColumn.Created or QuoteSortColumn.NextDue ? false : true;
        }

        await LoadPageAsync(1);
    }

    private void OpenQuote(Guid id)
    {
        Nav.NavigateTo("/quote/" + id);
    }

    private string SortIcon(QuoteSortColumn col)
    {
        if (sortColumn != col) return "";
        return sortAsc ? " ▲" : " ▼";
    }

    private enum QuoteSortColumn
    {
        Client,
        Reference,
        Value,
        Status,
        Owner,
        NextDue,
        Created
    }
}