@page "/lead-history"
@rendermode InteractiveServer
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using QuoteTrack.Application.Interfaces
@using QuoteTrack.Domain.Entities
@using QuoteTrack.Domain.Enums

@inject IQuoteService QuoteService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager

<PageTitle>Lead History</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1"><i class="bi bi-clock-history text-secondary me-2"></i>Lead History</h2>
        <div class="text-muted small">
            @(isAdminOrHead ? "Historical / submitted leads across the team." : "Your historical / submitted leads.")
        </div>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary" @onclick="LoadData">
            <i class="bi bi-arrow-clockwise me-1"></i> Refresh
        </button>
        <button class="btn btn-outline-primary" @onclick="BackToLeads">
            <i class="bi bi-arrow-left me-1"></i> Back
        </button>
    </div>
</div>

@if (isAdminOrHead)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">Representative</label>
                    <select class="form-select" @bind="selectedOwnerId">
                        <option value="">All Representatives</option>
                        <option value="@UnassignedOwnerValue">Unassigned Only</option>
                        @foreach (var user in systemUsers.OrderBy(x => x.FullName))
                        {
                            <option value="@user.Id">@user.FullName</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">Status</label>
                    <select class="form-select" @bind="selectedStatus">
                        <option value="">All History Statuses</option>
                        @foreach (var s in HistoryStatuses)
                        {
                            <option value="@s.ToString()">@s.ToString()</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">Search</label>
                    <input class="form-control" @bind="searchText" placeholder="Client / subject / reference / sender" />
                </div>
            </div>
        </div>
    </div>
}

@if (isLoading)
{
    <div class="text-center mt-5"><div class="spinner-border text-primary"></div></div>
}
else if (!FilteredHistory().Any())
{
    <div class="card shadow-sm border-0 text-center py-5">
        <div class="card-body">
            <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
            <h4 class="mt-3 fw-bold text-dark">No Lead History Found</h4>
            <p class="text-muted">Nothing matches the current filter.</p>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3">Client / Ref</th>
                            @if (isAdminOrHead)
                            {
                                <th>Representative</th>
                            }
                            <th>Status</th>
                            <th>Submitted At</th>
                            <th>Closed At</th>
                            <th>Last Due</th>
                            <th class="text-end pe-3">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lead in FilteredHistory())
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-bold text-primary">
                                        @(lead.Client?.CompanyName ?? lead.ClientName ?? "Unknown Client")
                                    </div>
                                    <div class="small text-muted font-monospace">@((string.IsNullOrWhiteSpace(lead.QuoteReference)) ? "—" : lead.QuoteReference)</div>
                                    <div class="small text-muted text-truncate" style="max-width: 260px;" title="@lead.Subject">@lead.Subject</div>
                                </td>

                                @if (isAdminOrHead)
                                {
                                    <td>@GetOwnerName(lead)</td>
                                }

                                <td>
                                    <span class="badge @GetStatusBadgeClass(lead.Status)">
                                        @lead.Status
                                    </span>
                                </td>

                                <td>
                                    @(lead.RepCompletedAt.HasValue? lead.RepCompletedAt.Value.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt") : "-")
                                </td>

                                <td>
                                    @(lead.ClosedAt.HasValue? lead.ClosedAt.Value.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt") : "-")
                                </td>

                                <td>
                                    @(lead.NextFollowUpDate.HasValue? lead.NextFollowUpDate.Value.ToLocalTime().ToString("dd MMM yyyy") : "-")
                                </td>

                                <td class="text-end pe-3">
                                    <button class="btn btn-sm btn-outline-primary fw-bold"
                                            @onclick="() => OpenLead(lead.Id)">
                                        Open
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private const string UnassignedOwnerValue = "__unassigned__";

    private bool isLoading = true;
    private bool isAdminOrHead = false;
    private string? currentUserId;

    private List<Quote> historyLeads = new();
    private List<ApplicationUser> systemUsers = new();

    private string selectedOwnerId = "";
    private string selectedStatus = "";
    private string searchText = "";

    private static readonly List<QuoteStatus> HistoryStatuses = new()
    {
        QuoteStatus.LeadRepCompleted,
        QuoteStatus.LeadClosed,
        QuoteStatus.NoResponse
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        currentUserId = UserManager.GetUserId(user);

        var isAdmin = user.IsInRole("Admin");
        var isHead = user.IsInRole("DeptHead") ||
                     user.IsInRole("DepartmentHead") ||
                     user.IsInRole("Head") ||
                     user.IsInRole("Manager");

        isAdminOrHead = isAdmin || isHead;

        await LoadData();
        isLoading = false;
    }

    private async Task LoadData()
    {
        isLoading = true;

        systemUsers = await QuoteService.GetSystemUsersAsync();

        var all = await QuoteService.GetAllQuotesAsync(isAdminOrHead ? null : currentUserId, isAdminOrHead);

        historyLeads = all
            .Where(q => q.RecordType == QuoteRecordType.Lead)
            .Where(q => !q.IsDeleteRequested)
            .Where(q =>
                q.Status == QuoteStatus.LeadRepCompleted ||
                q.Status == QuoteStatus.LeadClosed ||
                q.Status == QuoteStatus.NoResponse)
            .OrderByDescending(q => q.ClosedAt ?? q.RepCompletedAt ?? q.UpdatedAt)
            .ToList();

        isLoading = false;
    }

    private IEnumerable<Quote> FilteredHistory()
    {
        IEnumerable<Quote> q = historyLeads;

        if (isAdminOrHead)
        {
            if (!string.IsNullOrWhiteSpace(selectedOwnerId))
            {
                if (selectedOwnerId == UnassignedOwnerValue)
                    q = q.Where(x => string.IsNullOrWhiteSpace(x.OwnerId));
                else
                    q = q.Where(x => x.OwnerId == selectedOwnerId);
            }

            if (!string.IsNullOrWhiteSpace(selectedStatus) &&
                Enum.TryParse<QuoteStatus>(selectedStatus, out var parsedStatus))
            {
                q = q.Where(x => x.Status == parsedStatus);
            }

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                var s = searchText.Trim();

                q = q.Where(x =>
                    (x.Client?.CompanyName ?? x.ClientName ?? x.SenderEmail ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (x.QuoteReference ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (x.Subject ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (x.SenderEmail ?? "").Contains(s, StringComparison.OrdinalIgnoreCase));
            }
        }

        return q;
    }

    private string GetOwnerName(Quote lead)
    {
        if (lead.Owner != null && !string.IsNullOrWhiteSpace(lead.Owner.FullName))
            return lead.Owner.FullName;

        if (!string.IsNullOrWhiteSpace(lead.OwnerId))
        {
            var u = systemUsers.FirstOrDefault(x => x.Id == lead.OwnerId);
            if (u != null) return u.FullName;
        }

        return "Unassigned";
    }

    private string GetStatusBadgeClass(QuoteStatus status)
    {
        return status switch
        {
            QuoteStatus.LeadClosed => "bg-dark text-white",
            QuoteStatus.LeadRepCompleted => "bg-success text-white",
            QuoteStatus.NoResponse => "bg-danger text-white",
            _ => "bg-secondary text-white"
        };
    }

    private void OpenLead(Guid id)
    {
        NavManager.NavigateTo($"/lead/{id}");
    }

    private void BackToLeads()
    {
        NavManager.NavigateTo("/myleads");
    }
}